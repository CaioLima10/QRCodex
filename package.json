{
  "name": "holiver-qrcode",
  "productName": "HoliverQRCode",
  "version": "1.0.1",
  "description": "QR Code Generator",
  "author": "Caio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/run-electron-builder.js",
    "win": "node scripts/run-electron-builder.js --win",
    "linux": "node scripts/run-electron-builder.js --linux",
    "mac": "node scripts/run-electron-builder.js --mac",
    "dist": "node scripts/run-electron-builder.js --dir"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.sublimecia.holiverqrcode",
    "productName": "HoliverQRCode",
    "artifactName": "HoliverQRCode - Setup.${ext}",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "compression": "maximum",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "CaioLima10",
        "repo": "QRCodex"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "splash.html",
      "build/**/*",
      "node_modules/**/*",
      "!**/*.map",
      "!**/test/*",
      "!**/tests/*",
      "!**/*.md",
      "!**/*.ts",
      "!**/.git*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "build/app.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "maintainer": "Caio",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/app.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HoliverQRCode",
      "installerIcon": "build/app.ico",
      "uninstallerIcon": "build/app.ico",
      "installerHeaderIcon": "build/app.ico"
    }
  }
}