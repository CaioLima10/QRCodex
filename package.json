{
  "name": "holiver-qrcode",
  "productName": "HoliverQRCode",
  "version": "2.0.5",
  "description": "QR Code Generator",
  "author": "Caio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "validate": "node scripts/validate-build.js",
    "validate-platform": "node scripts/validate-platform.js",
    "test-all": "node scripts/test-all.js",
    "test-professional": "node scripts/professional-test.js",
    "test-human-error": "node scripts/human-error-test.js",
    "github-actions-test": "node scripts/github-actions-test.js",
    "code-quality-test": "node scripts/code-quality-test.js",
    "lint-test": "node scripts/lint-test.js",
    "ultimate-test": "node scripts/ultimate-test.js",
    "test-final": "node scripts/final-validation.js",
    "prebuild": "npm run code-quality-test",
    "build": "electron-builder --publish never",
    "build-nsis": "node scripts/build-nsis.js",
    "win": "electron-builder --win --x64 --publish never",
    "win-x86": "electron-builder --win --ia32 --publish never",
    "linux": "electron-builder --linux --x64 --publish never",
    "linux-arm": "electron-builder --linux --arm64 --publish never",
    "mac": "electron-builder --mac --x64 --publish never",
    "mac-arm": "electron-builder --mac --arm64 --publish never",
    "build-all": "electron-builder --win --linux --mac --publish never",
    "install:app": "node installer/install.js",
    "install:verify": "node installer/verify-install.js",
    "install:status": "node installer/verify-install.js",
    "uninstall:app": "node uninstaller/uninstall.js",
    "uninstall:verify": "node uninstaller/verify-uninstall.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.sublimecia.holiverqrcode",
    "productName": "HoliverQRCode",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "compression": "maximum",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "splash.html",
      "logo.png",
      "icon.png",
      "build/**/*",
      "node_modules/**/*",
      "!**/*.map",
      "!**/test/*",
      "!**/tests/*",
      "!**/*.md",
      "!**/*.ts",
      "!**/.git*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "build/app.ico"
    },
    "linux": {
      "maintainer": "Caio",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/app.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HoliverQRCode",
      "uninstallDisplayName": "HoliverQRCode",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "perMachine": false
    }
  }
}